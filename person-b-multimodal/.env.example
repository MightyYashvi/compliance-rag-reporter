# === LLM Provider ===
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Which LLM to use for report generation: "claude" or "openai"
LLM_PROVIDER=claude
# Model names
CLAUDE_MODEL=claude-sonnet-4-20250514
OPENAI_MODEL=gpt-4o

# === Whisper ===
# "local" = run whisper locally (requires ~1.5GB VRAM for base model)
# "api"   = use OpenAI Whisper API (requires OPENAI_API_KEY)
WHISPER_MODE=api
WHISPER_LOCAL_MODEL=base

# === OCR ===
# "tesseract" = local Tesseract OCR
# "vision"    = use LLM vision API (Claude or OpenAI) for image understanding
OCR_MODE=tesseract

# === RAG (Person A's service) ===
RAG_SERVICE_URL=http://localhost:8001
# If Person A's RAG isn't up yet, set to "true" to use mock retrieval
RAG_MOCK=true

# === Server ===
HOST=0.0.0.0
PORT=8000
DEBUG=true

# === Storage ===
UPLOAD_DIR=./uploads
REPORTS_DIR=./reports
